{
  "name": "@shekohex/agent",
  "version": "0.70.0",
  "private": true,
  "author": {
    "name": "Shady Khalifa",
    "email": "dev+npm@shadykhalifa.me",
    "url": "https://shadykhalifa.me"
  },
  "bin": {
    "pi": "./bin/pi.js"
  },
  "files": [
    "bin",
    "dist",
    "patches",
    "scripts"
  ],
  "type": "module",
  "scripts": {
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "oxlint -f stylish",
    "lint:fix": "oxlint --fix",
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "test": "vitest run",
    "test:json": "vitest run --reporter=json --outputFile=/tmp/vitest-results.json && echo /tmp/vitest-results.json",
    "test:coverage": "vitest run --coverage",
    "build": "tsc -p tsconfig.json && node ./scripts/copy-bundled-resources.mjs && node ./scripts/generate-default-settings.mjs && node ./scripts/prepare-bin.mjs",
    "prepare": "npm run build",
    "postinstall": "node ./scripts/postinstall.mjs",
    "postprepare": "node ./scripts/postinstall.mjs",
    "pi": "PI_SKIP_VERSION_CHECK=1 tsx src/cli.ts",
    "preview:tools": "node --import tsx ./scripts/preview-tools.ts --watch",
    "preview:tools:once": "node --import tsx ./scripts/preview-tools.ts",
    "preview:tools:watch": "node --import tsx ./scripts/preview-tools.ts --watch",
    "patch:deps": "patch-package",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:executor": "vitest run ./test/executor.test.ts",
    "test:keys": "vitest run ./test/pi-tui-keys.test.ts",
    "test:tool-preview": "vitest run ./test/tool-preview.test.ts",
    "test:harness": "vitest run ./test/harness.test.ts ./test/review.test.ts ./test/coreui-editor.test.ts ./test/coreui-builtins.test.ts",
    "test:subagent": "vitest run ./test/commit.test.ts ./test/subagent.test.ts ./test/subagent-sdk.test.ts"
  },
  "dependencies": {
    "@mariozechner/pi-coding-agent": "0.70.0",
    "@mendable/firecrawl-js": "^4.18.1",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@oxlint/plugins": "^1.61.0",
    "@types/json-schema": "^7.0.15",
    "beautiful-mermaid": "^1.1.3",
    "diff": "^8.0.4",
    "mermaid": "^11.14.0",
    "patch-package": "8.0.1",
    "typebox": "^1.1.24"
  },
  "devDependencies": {
    "@marcfargas/pi-test-harness": "^0.5.0",
    "@types/node": "^20.11.17",
    "@vitest/coverage-v8": "^4.1.5",
    "@vitest/ui": "^4.1.5",
    "oxfmt": "^0.44.0",
    "oxlint": "^1.59.0",
    "oxlint-tsgolint": "^0.21.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vite": "^8.0.10",
    "vitest": "^4.1.5"
  },
  "piConfig": {
    "name": "pi",
    "configDir": ".pi"
  }
}
