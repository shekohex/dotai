{
  "name": "@shekohex/agent",
  "version": "0.67.3",
  "private": true,
  "author": {
    "name": "Shady Khalifa",
    "email": "dev+npm@shadykhalifa.me",
    "url": "https://shadykhalifa.me"
  },
  "bin": {
    "pi": "./bin/pi.js"
  },
  "files": [
    "bin",
    "dist",
    "patches",
    "scripts"
  ],
  "type": "module",
  "scripts": {
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "test": "npm run test:keys && npm run test:tool-preview && npm run test:executor && npm run test:harness && npm run test:subagent",
    "build": "tsc -p tsconfig.json && node ./scripts/copy-bundled-resources.mjs && node ./scripts/generate-default-settings.mjs && node ./scripts/prepare-bin.mjs",
    "prepare": "npm run build",
    "postinstall": "node ./scripts/postinstall.mjs",
    "postprepare": "node ./scripts/postinstall.mjs",
    "pi": "PI_SKIP_VERSION_CHECK=1 tsx src/cli.ts",
    "remote": "tsx watch src/remote/index.ts",
    "preview:tools": "node --import tsx ./scripts/preview-tools.ts --watch",
    "preview:tools:once": "node --import tsx ./scripts/preview-tools.ts",
    "preview:tools:watch": "node --import tsx ./scripts/preview-tools.ts --watch",
    "patch:deps": "patch-package",
    "test:executor": "node --import tsx --test ./test/executor.test.ts",
    "test:keys": "node --import tsx --test ./test/pi-tui-keys.test.ts",
    "test:tool-preview": "node --import tsx --test ./test/tool-preview.test.ts",
    "test:harness": "node --import tsx --test ./test/harness.test.ts ./test/review.test.ts",
    "test:subagent": "node --import tsx --test ./test/commit.test.ts ./test/subagent.test.ts ./test/subagent-sdk.test.ts"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.14",
    "@mariozechner/pi-coding-agent": "0.67.3",
    "@mendable/firecrawl-js": "^4.18.1",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@sinclair/typebox": "^0.34.41",
    "beautiful-mermaid": "^1.1.3",
    "diff": "^8.0.4",
    "hono": "^4.12.14",
    "mermaid": "^11.14.0",
    "patch-package": "8.0.1"
  },
  "devDependencies": {
    "@types/node": "^20.11.17",
    "@marcfargas/pi-test-harness": "^0.5.0",
    "oxfmt": "^0.44.0",
    "oxlint": "^1.59.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  },
  "piConfig": {
    "name": "pi",
    "configDir": ".pi"
  }
}
