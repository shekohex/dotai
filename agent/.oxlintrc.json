{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["typescript", "unicorn", "oxc", "node", "jsdoc", "import"],
  "jsPlugins": ["./support/oxlint-plugin-project-rules/index.mjs"],
  "categories": {
    "correctness": "error",
    "pedantic": "error",
    "suspicious": "error"
  },
  "ignorePatterns": [
    ".pi/extensions/forbid.ts",
    "src/resources/gsd/bin/**",
    "support/pi-test-harness/**",
    "resources/plannotator/**",
    "src/extensions/plannotator/generated/**",
    "src/resources/workflows/**",
    "test/**",
    "vendor/**",
    "**/**/*.test.ts"
  ],
  "options": {
    "typeAware": true,
    "typeCheck": true,
    "reportUnusedDisableDirectives": "error"
  },
  "rules": {
    "import/max-dependencies": [
      "error",
      {
        "max": 15
      }
    ],
    "max-lines": [
      "error",
      {
        "max": 750,
        "skipComments": true,
        "skipBlankLines": true
      }
    ],
    "max-lines-per-function": [
      "error",
      {
        "max": 128,
        "skipComments": true,
        "skipBlankLines": true
      }
    ],
    "typescript/no-explicit-any": "error",
    "typescript/no-unsafe-type-assertion": "error",
    "typescript/no-unsafe-assignment": "error",
    "no-nested-ternary": "error",
    "project-rules/no-dynamic-import": "error",
    "project-rules/no-inline-import-type": "error",
    "project-rules/no-reflect-outside-allowlist": [
      "error",
      {
        "allowFiles": [
          "src/extensions/bundled-resources.ts",
          "src/extensions/model-family-system-prompt.ts"
        ]
      }
    ],
    "project-rules/no-redundant-runtime-narrowing": [
      "error",
      {
        "checks": ["typeof", "array", "in"],
        "allowFiles": ["src/extensions/subagent/render-state.ts", "src/extensions/modes/events.ts"]
      }
    ],
    "project-rules/no-redundant-check-after-typebox": "error",
    "project-rules/no-object-shape-cast-from-unknown": "error",
    "project-rules/no-unsafe-json-parse": "error",
    "project-rules/no-inline-error-message-extraction": "error",
    "project-rules/no-local-unknown-record-helper": "error"
  },
  "overrides": [
    {
      "files": ["src/extensions/interview/form/script.js"],
      "rules": {
        "no-unsafe-assignment": "off",
        "max-lines": "off"
      }
    }
  ],
  "env": {
    "builtin": true
  }
}
