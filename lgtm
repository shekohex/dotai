#!/usr/bin/env bash
set -euo pipefail

readonly BASE_PROMPT='Review staged and unstaged git changes. Create atomic conventional commits. Report commits created and warn if uncommitted changes remain.'

show_help() {
  cat <<'EOF'
Usage: lgtm [OPTIONS] [PROMPT...]

Thin wrapper around:
  pi --no-session --mode-commiter -p "<PROMPT>"

Options:
  -p, --prompt TEXT  Append additional instructions to prompt
  -h, --help         Show this help message

Examples:
  lgtm
  lgtm -p "Focus on src/"
  lgtm "Split unrelated changes into separate commits"
EOF
}

main() {
  local -a prompt_segments=()

  while [[ $# -gt 0 ]]; do
    case "$1" in
    -p | --prompt)
      if [[ $# -lt 2 ]]; then
        echo "lgtm: $1 requires an argument" >&2
        exit 1
      fi
      prompt_segments+=("$2")
      shift 2
      ;;
    -h | --help)
      show_help
      exit 0
      ;;
    --)
      shift
      while [[ $# -gt 0 ]]; do
        prompt_segments+=("$1")
        shift
      done
      ;;
    *)
      prompt_segments+=("$1")
      shift
      ;;
    esac
  done

  local prompt="$BASE_PROMPT"
  if [[ ${#prompt_segments[@]} -gt 0 ]]; then
    prompt+=$'\n\nAdditional instructions:\n'
    prompt+=$(printf '%s\n' "${prompt_segments[@]}")
  fi

  exec pi --no-session --mode-commiter -p "$prompt"
}

main "$@"
